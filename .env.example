# --- Wallet / Chain ---
BSC_RPC_URL=https://bsc-dataseed.binance.org
BSC_CHAIN_ID=56
USDT_CONTRACT=0x55d398326f99059fF775485246999027B3197955
WBNB_CONTRACT=0xbb4CdB9CBd36B01bD1cBaEBF2De08d9173bc095c
PANCAKE_ROUTER=0x10ED43C718714eb63d5aA57B78B54704E256024E

# --- TWAK (Trust Wallet Agent Kit) ---
# Install the CLI:  npm i -g @trustwallet/cli
# Enable the REAL TWAK path (required for the prize AND for perps) by setting the
# two credentials below (from `twak setup`). When they're set + the CLI is present,
# the agent creates/uses a TWAK-managed wallet, routes spot swaps + BSC PERPS +
# `twak compete register` through TWAK. When absent, spot falls back to a local
# web3 keystore (data_store/agent_keystore.json) and PERPS ARE DISABLED (Aster/HL
# perps require the TWAK CLI; there is no raw-web3 fallback).
TWAK_BIN=twak
TWAK_PROFILE=xorr
TWAK_PASSWORD=        # Password for the encrypted agent wallet; never log
TWAK_ACCESS_ID=
TWAK_HMAC_SECRET=

# --- Data providers ---
CMC_API_KEY=your_coinmarketcap_api_key
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
FEAR_GREED_URL=https://api.alternative.me/fng/?limit=2

# --- Risk defaults (tuned for a ~$50-70 competition wallet) ---
SCAN_INTERVAL_SEC=180
MAX_CONCURRENT_POSITIONS=5
BASE_TRADE_SIZE_USD=2.0       # spot notional per trade (scaled by confidence/F&G/drawdown)
SLIPPAGE_BPS_SPOT=150
SLIPPAGE_BPS_NEWS=300
CEX_DEVIATION_BPS=300   # CMC-vs-CEX price sanity bound (bps). 120 was too tight and blocked majors; 300 still rejects gross token mismatches.
LIQUIDITY_IMPACT_BPS=150
ENABLE_NEWS_CATALYST=true

# --- Simulation seeding (mirror the live wallet so paper PnL is representative) ---
SIM_START_USDT=42.0          # mirror your live USDT (~$42 of a $50 budget; the rest is BNB gas)
SIM_START_BNB=0.03

# --- Venue: SPOT ONLY (default for this competition) ---
# The hackathon allows SPOT trading only. In spot_only mode the proven reversion
# strategies still run as signal sources on the liquid majors, but only their LONG
# side is taken and it executes as a 1x PancakeSwap swap (web3 keystore — no TWAK,
# no leverage, NO liquidation risk). Set SPOT_ONLY=false only if perps are allowed.
SPOT_ONLY=true

# --- Perpetual futures (BSC perps via TWAK -> Aster/Hyperliquid) ---
# Perps let the agent SHORT and use leverage, but are DISABLED for the spot-only
# competition. These knobs only take effect if SPOT_ONLY=false AND ENABLE_PERPS=true.
ENABLE_PERPS=false
PERP_LEVERAGE=3.0             # 2-5x recommended; liquidation ~ (1/lev) away from entry
PERP_MAX_LEVERAGE=5.0
PERP_USD_IS_MARGIN=true       # twak perps --usd = MARGIN. VERIFY with one $1 dust perp + `twak perps positions`
PERP_MARGIN_PCT_PER_TRADE=0.12   # max margin per perp = 12% of equity
PERP_TOTAL_MARGIN_PCT=0.30       # max TOTAL perp margin = 30% of equity
PERP_MIN_MARGIN_USD=5.0          # venue minimum order floor
PERP_LIQ_GUARD_PCT=6.0           # force-close a perp if mark gets within 6% of liquidation
PERP_SYMBOLS=ETH,BNB,XRP,DOGE,ADA,AVAX,LINK   # eligible+quoted majors only (BTC/SOL aren't on the 149)

# --- Drawdown disqualification gate (competition rule: ~30% max DD = DISQUALIFIED) ---
# Ranked by total return, BUT blowing past the DD cap disqualifies you outright.
# We flatten + pause (recoverable) at 22%, hard-halt at 27%, never reaching 30%.
DQ_DRAWDOWN_PCT=30.0
FLATTEN_DRAWDOWN_PCT=22.0
RISK_PAUSE_MIN=120.0

# --- ERC-8004 (BRC8004) agent registration on BNB Chain ---
# IdentityRegistry on BSC mainnet (verified deployed). register(agentURI) is nonpayable
# (only ~$0.01 gas). Register with: python -m scripts.register_agent --send
ERC8004_REGISTRY_ADDRESS=0xfA09B3397fAC75424422C4D28b1729E3D4f659D7
# URI to your off-chain agent card JSON (defaults to the repo's agent_card.json on GitHub;
# override if you fork/rename the repo or host it elsewhere, e.g. IPFS).
AGENT_CARD_URI=https://raw.githubusercontent.com/nickthelegend/xorr-agent-backend/master/agent_card.json

# --- Mode ---
START_MODE=simulation
